PORT=3001
NODE_ENV=development

# Database — leave blank locally (uses SQLite automatically).
# On Render, set this to your Neon connection string in the Render dashboard.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Adzuna — the only free source with native BE + NL + LU coverage.
# Get a free instant key at https://developer.adzuna.com/signup
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Gemini AI — primary LLM for fit scoring + RAG (1,500 req/day free).
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq — fallback LLM. Get a free key at https://console.groq.com
GROQ_API_KEY=

# The Muse — optional supplemental source.
# Get a free key at https://www.themuse.com/developers/api/v2
THE_MUSE_API_KEY=
